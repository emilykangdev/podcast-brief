# =============================================================================
# Server Schedule Briefs — Environment Variables
# =============================================================================
# Copy to .env.local for local dev. For Railway, set in the Variables tab.
#
# IMPORTANT: Each environment (dev, staging, prod) needs its OWN keys
# so you can track costs per environment and isolate failures.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Create THREE separate Supabase projects and run migrations on all three:
#   - server-schedule-briefs-dev
#   - server-schedule-briefs-staging
#   - server-schedule-briefs-prod
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ── Deepgram ─────────────────────────────────────────────────────────────────
# Same Deepgram account. Create 3 API keys named dev / staging / prod.
# Filter usage by key name in the dashboard for cost tracking.
DEEPGRAM_API_KEY=

# ── OpenRouter ───────────────────────────────────────────────────────────────
# Same account, 3 API keys: dev / staging / prod
OPENROUTER_API_KEY=

# ── Exa ──────────────────────────────────────────────────────────────────────
# Same account, 3 API keys if supported (low cost, shared is OK as fallback)
EXA_API_KEY=

# ── Resend ───────────────────────────────────────────────────────────────────
# Dev + Staging: use your personal email as recipient so no real users get hit
# Prod: real API key with verified domain
RESEND_API_KEY=

# ── Browserbase ──────────────────────────────────────────────────────────────
# One account is fine. Use separate project IDs per env if possible.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Dev + Staging: sk_test_... / pk_test_... (Stripe test mode)
# Prod ONLY:     sk_live_... / pk_live_...
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Worker Auth ──────────────────────────────────────────────────────────────
# Generate a DIFFERENT secret per environment:
#   openssl rand -hex 32
# WORKER_URL is the Railway service URL (staging or prod)
WORKER_URL=
WORKER_SECRET=

# ── PostHog ──────────────────────────────────────────────────────────────────
# Same project key for client (posthog-js) and server (posthog-node).
# Set these in both the Next.js app AND the Railway worker service.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional: set to false to keep only AI metadata in PostHog (tokens, latency, cost, trace IDs).
# Default behavior logs full AI inputs/outputs for debugging.
POSTHOG_CAPTURE_AI_CONTENT=true

# ── Alerts ───────────────────────────────────────────────────────────────────
# Point each env at a different webhook/channel:
#   Dev:     unset or personal channel
#   Staging: #staging-alerts
#   Prod:    #prod-alerts (pages you)
WEBHOOK_URL=
